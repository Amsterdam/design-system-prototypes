{
  "version": "0.0.0",
  "author": "City of Amsterdam",
  "description": "Prototyping environment for the Amsterdam Design System",
  "name": "design-system-prototypes",
  "private": true,
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "type": "module",
  "scripts": {
    "add": "plop",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "link": "pnpm add @amsterdam/design-system-assets@link:../design-system/packages-proprietary/assets @amsterdam/design-system-css@link:../design-system/packages/css @amsterdam/design-system-react@link:../design-system/packages/react @amsterdam/design-system-react-icons@link:../design-system/packages-proprietary/react-icons @amsterdam/design-system-tokens@link:../design-system/packages-proprietary/tokens && pnpm install",
    "unlink": "pnpm add @amsterdam/design-system-assets@2.3.0 @amsterdam/design-system-css@4.1.0 @amsterdam/design-system-react@4.1.0 @amsterdam/design-system-react-icons@2.0.0 @amsterdam/design-system-tokens@4.0.1 && pnpm install",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "update": "npm-check-updates --upgrade && npm install",
    "update:minor": "npm-check-updates --target minor --upgrade && npm install",
    "update:patch": "npm-check-updates --target patch --upgrade && npm install"
  },
  "dependencies": {
    "@amsterdam/design-system-assets": "2.3.0",
    "@amsterdam/design-system-css": "4.1.0",
    "@amsterdam/design-system-react": "4.1.0",
    "@amsterdam/design-system-react-icons": "2.0.0",
    "@amsterdam/design-system-tokens": "4.0.1",
    "clsx": "2.1.1",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "npm-check-updates": "22.2.2",
    "plop": "4.0.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ]
}
